{
  "compilerOptions": {
    // Environment setup & latest features
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "Preserve",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "allowJs": true,
    "types": ["bun"],

    // Bundler mode
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    // Monorepo: resolve workspace packages for `tsc --noEmit`
    // (paths without baseUrl resolve relative to this tsconfig)
    "paths": {
      "@harness/protocol": ["./packages/protocol/src/index.ts"],
      "@harness/client": ["./packages/client/src/index.ts"]
    },

    // Best practices
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,

    // Some stricter flags (disabled by default)
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false
  },
  // apps/ide is a DOM/renderer app (needs the DOM lib); it is typechecked on its
  // own via `tsc -p apps/ide/tsconfig.json` so the server stays Bun-pure here
  // (the DOM lib's ReadableStream is not async-iterable and would break the harness).
  "include": ["apps", "packages"],
  "exclude": ["apps/ide", "**/node_modules", "**/dist"]
}
