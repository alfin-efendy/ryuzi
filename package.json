{
  "name": "ryuzi-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc --noEmit -p apps/cockpit && tsc --noEmit -p packages/ui",
    "cockpit:dev": "cd apps/cockpit && bun run tauri dev",
    "cockpit:build": "cd apps/cockpit && bun run tauri build",
    "e2e:cockpit": "bun run --cwd apps/cockpit e2e",
    "lint": "biome ci .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@happy-dom/global-registrator": "^20.10.6",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
