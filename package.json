{
  "name": "harness-monorepo",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit && tsc -p apps/ide/tsconfig.json --noEmit",
    "hr": "bun run apps/router/src/cli/index.ts",
    "lint": "biome ci .",
    "format": "biome check --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@types/bun": "latest",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5"
  }
}
