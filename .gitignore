# dependencies (bun install)
node_modules
**/node_modules

# runtime data (sqlite db lives outside the repo by default; ignore any local copies)
*.sqlite
*.sqlite-shm
*.sqlite-wal

# output
out
dist
*.tgz

# code coverage
coverage
*.lcov

# logs
logs
*.log
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# caches
.eslintcache
.cache
*.tsbuildinfo

# IntelliJ based IDEs
.idea

# Finder (MacOS) folder config
.DS_Store

# local-only dev artifacts kept locally, not published
docs/superpowers/
.superpowers/

# npm wrapper binaries are copied in at release time, never committed
npm/platform/*/ryuzi
npm/platform/*/ryuzi.exe

/target
# Local cargo state stays ignored, but the tracked alias file is real config
# (`cargo gen-bindings` — see apps/cockpit/src-tauri/Cargo.toml).
/.cargo/*
!/.cargo/config.toml

# Local agent/skill tooling artifacts (session-local, not part of the repo)
.agents/
.claude/
skills-lock.json

# Design specs/plans are kept as a local-only artifact (not tracked in origin)
docs/design/

# playwright output (apps/cockpit e2e)
apps/cockpit/playwright-report/
apps/cockpit/test-results/

# insta pending-snapshot artifacts (accepted .snap files are committed)
*.snap.new
